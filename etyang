<!DOCTYPE html>
<html>
<head>
<title>My Online Business</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
<h1>Welcome to My Business</h1>
<p>Quality digital services for everyone</p>
</header>

<nav>
<a href="#">Home</a>
<a href="#">Products</a>
<a href="#">About</a>
<a href="#">Contact</a>
</nav>

<section class="hero">
<h2>Grow Your Business With Us</h2>
<button>Shop Now</button>
</section>

<section class="products">

<div class="card">
<h3>Web Design</h3>
<p>Professional websites for businesses</p>
<button>Order</button>
</div>

<div class="card">
<h3>Graphic Design</h3>
<p>Posters, logos and branding</p>
<button>Order</button>
</div>

<div class="card">
<h3>Digital Marketing</h3>
<p>Promote your business online</p>
<button>Order</button>
</div>

</section>

<footer>
<p>© 2026 My Online Business</p>
</footer>

</body>
</html>
body{
font-family: Arial;
margin:0;
background:#f4f4f4;
}

header{
background:#0d6efd;
color:white;
text-align:center;
padding:40px;
}

nav{
background:#222;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:10px;
text-decoration:none;
}

.hero{
background:#17a2b8;
color:white;
text-align:center;
padding:60px;
}

.products{
display:flex;
justify-content:center;
gap:20px;
padding:40px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0px 3px 10px rgba(0,0,0,0.2);
width:200px;
text-align:center;
}

button{
background:#28a745;
color:white;
border:none;
padding:10px 20px;
border-radius:5px;
cursor:pointer;
}
